{
  "name": "imi-pro",
  "version": "26.6.31",
  "description": "IMI PRO Desktop",
  "main": "main.js",
  "scripts": {
    "start": "node_modules\\electron\\dist\\electron.exe .",
    "dist": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.imipro.desktop",
    "productName": "IMI PRO",
    "copyright": "IMI PRO",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "IMI PRO"
    },
    "publish": {
      "provider": "github",
      "owner": "msapi7890",
      "repo": "IMI-PRO-Settings",
      "releaseType": "release"
    }
  }
}
